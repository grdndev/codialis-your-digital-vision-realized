{
  "name": "codialis-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Express + MySQL backend for the Codialis admin (auth JWT/bcrypt, HR data, site content)",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon --legacy-watch --watch src --ext js,json src/index.js",
    "db:init": "node src/initdb.js",
    "db:seed-admin": "node src/seed-admin.js"
  },
  "dependencies": {
    "@extractus/article-extractor": "^8.0.16",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "mysql2": "^3.11.5",
    "node-cron": "^3.0.3",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
