# Copy to .env and adjust. Never commit the real .env.
PORT=3001

# MySQL (matches docker-compose.yml). In the container use db:3306; for a local
# node process against the dockerised db use localhost:3307.
DATABASE_URL=mysql://codialis:codialis_dev@db:3306/codialis

# JWT signing secret — generate a long random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_secret
# Token lifetime
JWT_EXPIRES=12h

# First admin (patron). Used only by `npm run db:seed-admin`, once.
ADMIN_NAME=Direction
ADMIN_EMAIL=admin@codialis.com
ADMIN_PASSWORD=change_me_strong_password

# Set to "production" behind HTTPS so the auth cookie gets the Secure flag.
NODE_ENV=development

# Brevo — sends generated passwords to new employees by email.
# Get the key at https://app.brevo.com > SMTP & API > API Keys.
BREVO_API_KEY=xkeysib-your_key_here
# Sender must be a validated sender/domain in your Brevo account.
BREVO_SENDER_NAME=Codialis
BREVO_SENDER_EMAIL=admin@codialis.com
# Login link included in the welcome email.
APP_LOGIN_URL=https://landingback.codialis.com/admin
